<b:comment><!-- SUBSCRIBE WIDGET - Widget untuk subscribe/follow -->
</b:comment>
<div class='widget subscribe-widget'>
  <h3>Ikuti Blog Ini</h3>
  <p class='subscribe-text'>Dapatkan update postingan terbaru langsung ke email Anda.</p>
  <form action='#' class='subscribe-form' method='POST'>
    <input class='subscribe-email' name='email' placeholder='Masukkan email Anda' type='email' required='required' />
    <button class='btn btn-primary' type='submit'>Subscribe</button>
  </form>
</div>
