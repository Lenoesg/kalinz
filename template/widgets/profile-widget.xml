<b:comment><!-- PROFILE WIDGET - Widget untuk profil penulis/blogger -->
</b:comment>
<b:widget id='Profile1' locked='true' title='Profil' type='Profile'>
  <b:includable id='main' var='top'>
    <div class='widget profile-widget'>
      <img alt='<data:userUrl />' class='profile-avatar' expr:src='data:userProfilePhoto' />
      <div class='profile-info'>
        <h3><data:userUrl /></h3>
        <p class='profile-bio'><data:userAboutMe /></p>
        <b:if cond='data:userEmail'>
          <p><a expr:href='&quot;mailto:&quot; + data:userEmail'>Hubungi</a></p>
        </b:if>
      </div>
    </div>
  </b:includable>
</b:widget>
