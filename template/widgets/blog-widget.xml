<!-- WIDGET BLOG -->
<b:defaultmarkup type='Blog'>

    <b:includable id='main' var='this'>

        <b:include cond='data:view.isHomepage' name='recentPostTitle' />

        <b:include name='filterPostMessage' />

        <b:include name='emptyPostMessage' />

        <b:include name='errorPageMessage' />

        <div class='content'>
            <b:include name='breadcrumb' />
            <b:class cond='data:view.isSingleItem' name='content-single' />
            <b:with
                value='data:widgets.FeaturedPost filter (w =&gt; w.sectionId == &quot;main-content&quot;) map (w =&gt; w.postId)'
                var='featuredPostIds'>
                <b:with
                    value='data:view.isHomepage ? data:posts filter (post =&gt; post.id not in data:featuredPostIds) : data:posts'
                    var='posts'>
                    <b:loop index='i' values='data:posts' var='post'>
                        <b:include data='post' name='postAndComments' />
                    </b:loop>
                </b:with>
            </b:with>
        </div>

        <b:include cond='data:view.isMultipleItems' name='postPagination' />

    </b:includable>

    <b:includable id='postAndComments' var='post'>
        <article class='post-outer'>
            <b:attr cond='data:view.isSingleItem' name='class' value='post-outer-single' />
            <div class='post-content'>
                <b:include data='post' name='post' />
            </div>

            <b:if cond='data:view.isPost'>
                <b:include data='post' name='commentPicker' />
            </b:if>
        </article>
    </b:includable>

    <b:includable id='post' var='post'>
        <b:include data='post' name='postMetaCustom' />

        <b:if cond='data:view.isPage'>
            <b:include name='defaultStaticPage' />
            <b:elseif cond='data:view.isPost' />
            <b:include name='defaultPostPage' />
            <b:else />
            <b:include name='defaultHomepage' />
        </b:if>
    </b:includable>

    <b:includable id='commentPicker' var='post'>
        <b:if cond='data:post.showThreadedComments'>
            <b:include data='post' name='custom-comments' />
            <b:else />
            <b:include data='post' name='comments' />
        </b:if>
    </b:includable>

    <b:includable id='custom-comments' var='post'>

        <section class='comments comments-threaded'
            expr:data-embed='data:post.embedCommentForm'
            expr:data-num-comments='data:post.numberOfComments' id='comments'>
            <b:if cond='data:post.allowComments'>

                <h2 class='comments-title'>
                    <b:if cond='data:post.numberOfComments == 0'>
                        <data:messages.postAComment />
                        <b:else />
                        <b:message name='messages.numberOfComments'>
                            <b:param expr:value='data:post.numberOfComments'
                                name='numComments' />
                        </b:message>
                    </b:if>    
                <b:switch
                        var='data:blog.locale'><b:case value='id' />untuk<b:default /> for </b:switch>
                    &quot;<data:post.title />&quot; </h2>

                <b:if cond='data:post.numberOfComments &gt; 0'>
                    <div class='comment-thread toplevel-thread'>
                        <b:loop values='data:post.comments' var='comment'>
                            <b:if cond='!data:comment.inReplyTo'>
                                <b:include data='comment' name='custom-comments-comment' />
                            </b:if>
                        </b:loop>
                    </div>
                </b:if>

                <b:include data='post' name='custom-comments-pager' />

                <b:if cond='data:post.allowNewComments'>
                    <b:include data='post' name='custom-comments-form' />
                    <b:else />
                    <data:post.noNewCommentsText />
                </b:if>

            </b:if>
        </section>

    </b:includable>


    <b:includable id='custom-comments-comment' var='comment'>

        <div class='comment' expr:id='data:comment.anchorName'>

            <b:class cond='data:comment.authorClass' name='is-author' />
            <b:class cond='data:comment.isDeleted' name='is-deleted' />

            <div class='avatar-image-container'>
                <b:class
                    cond='data:comment.authorAvatarSrc == &quot;//resources.blogblog.com/img/blank.gif&quot;'
                    name='is-anonim' />

                <img alt='Comment Author Avatar' class='lazyload'
                    expr:data-src='resizeImage(data:comment.authorAvatarSrc, 68, &quot;1:1&quot;)'
                    height='45'
                    src='data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=='
                    width='45' />
            </div>

            <div class='comment-wrapper'>
                <div class='comment-starter'>
                    <div class='comment-block'>
                        <div class='comment-header'>
                            <cite class='user'>
                                <b:if cond='data:comment.authorUrl'>
                                    <a expr:href='data:comment.authorUrl' rel='nofollow'
                                        target='_blank'>
                                        <data:comment.author />
                                    </a>
                                    <b:else />
                                    <data:comment.author />
                                </b:if>
                            </cite>
                            <span class='icon user '>
                                <b:class cond='data:comment.extraIconClass'
                                    expr:name='data:comment.extraIconClass' />
                            </span>
                            <span class='datetime secondary-text'>
                                <a expr:href='data:comment.url' rel='nofollow'>
                                    <data:comment.timestamp />
                                </a>
                            </span>
                        </div>
                        <div class='comment-content'>
                            <data:comment.body />
                        </div>
                    </div>

                    <b:with
                        value='data:post.comments filter (i =&gt; i.inReplyTo == data:comment.id)'
                        var='replies'>
                        <b:if cond='data:replies.size &gt; 0'>
                            <div class='comment-replies'>
                                <b:loop values='data:replies' var='reply'>
                                    <b:include data='reply'
                                        name='custom-comments-comment-reply' />
                                </b:loop>
                            </div>
                        </b:if>
                    </b:with>

                    <div class='comment-footer'>
                        <b:if cond='!data:comment.isDeleted'>
                            <a class='btn-reply' expr:data-comment-id='data:comment.id'
                                href='javascript:;'>
                                <b:switch var='data:blog.locale'><b:case value='id' /> Balas<b:default />
                                    Reply</b:switch>
                            </a>
                        </b:if>
                        <span>
                            <b:class cond='data:comment.adminClass'
                                expr:name='data:comment.adminClass' />
                            <a class='a-delete' expr:href='data:comment.deleteUrl'
                                expr:title='data:top.deleteCommentMsg'>
                                <b:switch var='data:blog.locale'><b:case value='id' /> Hapus<b:default />
                                    Delete</b:switch>
                            </a>
                        </span>
                    </div>

                </div>

            </div>

        </div>

    </b:includable>


    <b:includable id='custom-comments-comment-reply' var='reply'>

        <div class='comment reply' expr:id='data:reply.anchorName'>

            <b:class cond='data:reply.authorClass' name='is-author' />
            <b:class cond='data:reply.isDeleted' name='is-deleted' />

            <div class='avatar-image-container'>
                <b:class
                    cond='data:reply.authorAvatarSrc == &quot;//resources.blogblog.com/img/blank.gif&quot;'
                    name='is-anonim' />

                <img alt='Comment Author Avatar' class='lazyload'
                    expr:data-src='resizeImage(data:reply.authorAvatarSrc, 68, &quot;1:1&quot;)'
                    height='36'
                    src='data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw=='
                    width='36' />

            </div>

            <div class='comment-block'>
                <div class='comment-header'>
                    <cite class='user'>
                        <b:if cond='data:reply.authorUrl'>
                            <a expr:href='data:reply.authorUrl' rel='nofollow'
                                target='_blank'>
                                <data:reply.author />
                            </a>
                            <b:else />
                            <data:reply.author />
                        </b:if>
                    </cite>
                    <span class='icon user '>
                        <b:class cond='data:reply.extraIconClass'
                            expr:name='data:reply.extraIconClass' />
                    </span>
                    <span class='datetime secondary-text'>
                        <a expr:href='data:reply.url' rel='nofollow'>
                            <data:reply.timestamp />
                        </a>
                    </span>
                </div>
                <div class='comment-content'>
                    <data:reply.body />
                </div>
                <div class='comment-footer'>
                    <span>
                        <b:class cond='data:reply.adminClass'
                            expr:name='data:reply.adminClass' />
                        <a class='a-delete' expr:href='data:reply.deleteUrl'
                            expr:title='data:top.deleteCommentMsg'>
                            <b:switch var='data:blog.locale'><b:case value='id' />Hapus<b:default />
                                Delete</b:switch>
                        </a>
                    </span>
                </div>
            </div>
        </div>
    </b:includable>


    <b:includable id='custom-comments-form' var='post'>

        <div class='custom-comment-form' id='custom-comment-form'>

            <b:if cond='data:this.messages.blogComment != &quot;&quot;'>
                <p class='comment-note'>
                    <data:this.messages.blogComment />
                </p>
            </b:if>

            <a aria-label='comment editor URL'
                expr:href='data:post.commentFormIframeSrc' id='comment-editor-src' />

            <div class='custom-comment-editor-wrapper'>
                <iframe class='blogger-iframe-colorize blogger-comment-from-post'
                    frameborder='0' id='comment-editor' name='comment-editor' src=''
                    style='width:100%;' title='comment-editor' width='200' />
            </div>

            <data:post.cmtfpIframe />

            <script>
            function createIframeComment() {
                BLOG_CMT_createIframe(&#39;<data:post.appRpcRelayPath/>&#39;, &#39;<data:post.communityId/>&#39;);
            }
            Defer(createIframeComment, 0, true);
        </script>

            <button class='btn-cancel'>
                <b:switch var='data:blog.locale'><b:case value='id' />Batal<b:default /> Cancel</b:switch>
            </button>

        </div>

    </b:includable>

    <b:includable id='custom-comments-pager' var='post'>
        <b:if cond='data:post.commentPagingRequired'>
            <nav class='custom-comments-pager'>
                <a expr:class='data:post.oldLinkClass'
                    expr:href='data:post.olderLinkUrl'>
                    <data:messages.older />
                </a>
                <a expr:class='data:post.oldLinkClass'
                    expr:href='data:post.oldestLinkUrl'>
                    <data:messages.oldest />
                </a>
                <span class='comments-range'>
                    <data:post.commentRangeText />
                </span>
                <a expr:class='data:post.newLinkClass'
                    expr:href='data:post.newestLinkUrl'>
                    <data:messages.newest />
                </a>
                <a expr:class='data:post.newLinkClass'
                    expr:href='data:post.newerLinkUrl'>
                    <data:messages.newer />
                </a>
            </nav>
        </b:if>
    </b:includable>

    <b:includable id='commentItem' var='comment'>

        <div class='comment' expr:id='&quot;c&quot; + data:comment.id'>

            <div class='comment-block'>

                <div class='comment-author'>
                    <span class='comment-author-name'>
                        <data:comment.author />
                    </span>

                    <span class='comment-timestamp'>
                        <data:comment.timestamp />
                    </span>

                    <span
                        expr:class='&quot;item-control &quot; + data:comment.adminClass'>
                        <b:if cond='data:showCmtPopup'>
                            <div class='goog-toggle-button'>
                                <div class='goog-inline-block comment-action-icon' />
                            </div>
                            <b:else />
                            <a class='comment-delete' expr:href='data:comment.deleteUrl'
                                expr:title='data:messages.deleteComment'>
                                <data:messages.deleteComment />
                            </a>
                        </b:if>
                    </span>

                </div>

                <div
                    expr:class='&quot;comment-body&quot; + (data:comment.isDeleted ? &quot; deleted&quot; : &quot;&quot;)'>
                    <data:comment.body />
                </div>

            </div>

        </div>

    </b:includable>

    <b:includable id='comments' var='post'>

        <section
            expr:class='&quot;comments comments-non-threaded&quot; + (data:post.embedCommentForm ? &quot; embed&quot; : &quot;&quot;)'
            expr:data-num-comments='data:post.numberOfComments' id='comments'>

            <a name='comments' />

            <b:if cond='data:post.allowComments'>

                <h2 class='comments-title'>
                    <b:if cond='data:post.numberOfComments == 0'>
                        <data:messages.postAComment />
                        <b:else />
                        <b:message name='messages.numberOfComments'>
                            <b:param expr:value='data:post.numberOfComments'
                                name='numComments' />
                        </b:message>
                    </b:if>    
                <b:switch
                        var='data:blog.locale'><b:case value='id' />untuk<b:default /> for </b:switch>
                    &quot;<data:post.title />&quot; </h2>

                <div
                    expr:id='data:widget.instanceId + &quot;_comments-block-wrapper&quot;'>
                    <b:include cond='data:post.comments' data='post.comments'
                        name='commentList' />
                </div>

                <b:if cond='data:post.commentPagingRequired'>
                    <div class='paging-control-container'>
                        <b:if cond='data:post.hasOlderLinks'>
                            <a expr:class='data:post.oldLinkClass'
                                expr:href='data:post.oldestLinkUrl'>
                                <data:messages.oldest />
                            </a>
                            <a expr:class='data:post.oldLinkClass'
                                expr:href='data:post.olderLinkUrl'>
                                <data:messages.older />
                            </a>
                        </b:if>

                        <span class='comment-range-text'>
                            <data:post.commentRangeText />
                        </span>

                        <b:if cond='data:post.hasNewerLinks'>
                            <a expr:class='data:post.newLinkClass'
                                expr:href='data:post.newerLinkUrl'>
                                <data:messages.newer />
                            </a>
                            <a expr:class='data:post.newLinkClass'
                                expr:href='data:post.newestLinkUrl'>
                                <data:messages.newest />
                            </a>
                        </b:if>
                    </div>
                </b:if>

                <div class='comment-footer'>
                    <b:if cond='data:post.embedCommentForm'>
                        <b:if cond='data:post.allowNewComments'>
                            <b:include data='post' name='commentForm' />
                            <b:else />
                            <data:post.noNewCommentsText />
                        </b:if>
                        <b:else />
                        <b:if cond='data:post.allowComments'>
                            <a class='post-comment-link'
                                expr:href='data:post.commentsUrl'
                                expr:onclick='data:post.commentsUrlOnclick'>
                                <b:message name='messages.postAComment' />
                            </a>
                            <b:if cond='data:this.messages.blogComment != &quot;&quot;'>
                                <p class='comment-note'>
                                    <data:this.messages.blogComment />
                                </p>
                            </b:if>
                        </b:if>
                    </b:if>
                </div>

            </b:if>

            <b:if cond='data:showCmtPopup'>
                <div id='comment-popup'>
                    <iframe allowtransparency='allowtransparency' frameborder='0'
                        id='comment-actions' name='comment-actions' scrolling='no'
                        title='comment-actions'>
                    </iframe>
                </div>
            </b:if>

        </section>

    </b:includable>

    <b:includable id='commentList' var='comments'>
        <div id='comments-block'>
            <b:loop values='data:comments' var='comment'>
                <b:include data='comment' name='commentItem' />
            </b:loop>
        </div>
    </b:includable>

    <b:includable id='nextPageLink'>
        <a class='blog-pager-older-link' expr:href='data:olderPageUrl'
            expr:id='data:widget.instanceId + &quot;_blog-pager-older-link&quot;'
            expr:title='data:messages.olderPosts'>
            <b:include name='olderPostTitle' />
        </a>
    </b:includable>

    <b:includable id='previousPageLink'>
        <a class='blog-pager-newer-link' expr:href='data:newerPageUrl'
            expr:id='data:widget.instanceId + &quot;_blog-pager-newer-link&quot;'
            expr:title='data:messages.newerPosts'>
            <b:include name='newerPostTitle' />
        </a>
    </b:includable>

    <b:includable id='postPagination'>
        <div class='blog-pager container' id='blog-pager'>
            <b:include cond='data:newerPageUrl' name='previousPageLink' />
            <b:include cond='data:olderPageUrl' name='nextPageLink' />
        </div>
    </b:includable>

    <b:includable id='olderPostTitle'>
        <data:messages.olderPosts />
    </b:includable>

    <b:includable id='newerPostTitle'>
        <data:messages.newerPosts />
    </b:includable>

</b:defaultmarkup>
<!-- WIDGET BLOG END -->