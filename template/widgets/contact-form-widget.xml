<b:comment><!-- CONTACT FORM WIDGET - Widget untuk form kontak -->
</b:comment>
<div class='widget contact-form-widget'>
  <h3>Form Kontak</h3>
  <form class='contact-form' method='POST'>
    <div class='form-group'>
      <label for='contact-name'>Nama</label>
      <input id='contact-name' name='name' required='required' type='text' />
    </div>
    <div class='form-group'>
      <label for='contact-email'>Email</label>
      <input id='contact-email' name='email' required='required' type='email' />
    </div>
    <div class='form-group'>
      <label for='contact-message'>Pesan</label>
      <textarea id='contact-message' name='message' required='required' rows='5'></textarea>
    </div>
    <button class='btn btn-primary' type='submit'>Kirim</button>
  </form>
</div>
