<b:comment><!-- STATS WIDGET - Widget untuk statistik blog -->
</b:comment>
<b:widget id='Stats1' locked='true' title='Statistik' type='Stats'>
  <b:includable id='main' var='top'>
    <div class='widget stats-widget'>
      <h3><data:title /></h3>
      <ul class='stats-list'>
        <li>
          <span class='stats-label'>Total Kunjungan:</span>
          <strong class='stats-value'><data:totalCount /></strong>
        </li>
        <li>
          <span class='stats-label'>Postingan:</span>
          <strong class='stats-value'><data:totalCount /></strong>
        </li>
      </ul>
    </div>
  </b:includable>
</b:widget>
