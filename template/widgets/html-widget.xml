<b:comment><!-- HTML WIDGET - Widget untuk custom HTML/CSS -->
</b:comment>
<b:widget id='HTML1' locked='true' title='Custom HTML' type='HTML'>
  <b:includable id='main' var='top'>
    <div class='widget html-widget'>
      <b:if cond='data:title'>
        <h3><data:title /></h3>
      </b:if>
      <div class='html-content'>
        <data:content />
      </div>
    </div>
  </b:includable>
</b:widget>
