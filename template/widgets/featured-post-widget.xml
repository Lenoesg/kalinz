<!-- WIDGET FEATURED POST -->
<b:defaultmarkup type='FeaturedPost'>

    <b:includable id='main' var='this'>
        <b:if cond='data:view.isHomepage'>
            <div class='featured-outer'>
                <b:if cond='data:title != &quot;&quot;'>
                    <h2 class='title'>
                        <data:title />
                    </h2>
                </b:if>
                <div class='post-summary'>
                    <b:loop values='data:posts' var='post'>
                        <b:include name='featuredImage' />
                        <div class='featured-info'>
                            <b:class cond='not data:postDisplay.showFeaturedImage'
                                name='no-featured-img' />
                            <b:include name='featuredTitle' />
                            <b:include name='featuredSnippet' />
                            <b:include name='featuredReadmore' />
                        </div>
                    </b:loop>
                </div>
            </div>
        </b:if>
    </b:includable>

    <b:includable id='featuredImage'>
        <b:if cond='data:postDisplay.showFeaturedImage'>
            <div class='featured-img'>
                <div class='featured-img-bg'>
                    <b:class cond='data:post.featuredImage.isYoutube' name='is-video' />
                    <b:if cond='data:post.featuredImage'>
                        <b:if cond='data:post.featuredImage.isYoutube'>
                            <a expr:href='data:post.link ?: data:post.url'>
                                <img class='image lazyload'
                                    expr:alt='data:post.title ? data:post.title : data:messages.image'
                                    expr:data-src='data:post.featuredImage.youtubeMaxResDefaultUrl.isResizable ? resizeImage(data:post.featuredImage.youtubeMaxResDefaultUrl, 400, &quot;1:1&quot;) : data:post.featuredImage.youtubeMaxResDefaultUrl'
                                    expr:srcset='resizeImage(data:post.featuredImage.youtubeMaxResDefaultUrl, 400, &quot;1:1&quot;) + &quot; 1x, &quot; + resizeImage(data:post.featuredImage.youtubeMaxResDefaultUrl, 800, &quot;1:1&quot;) + &quot; 2x&quot;'
                                    height='400'
                                    src='data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAABHNCSVQICAgIfAhkiAAAAAlwSFlzAAAD2AAAA9gBbkdjNQAAABl0RVh0U29mdHdhcmUAd3d3Lmlua3NjYXBlLm9yZ5vuPBoAAAANSURBVAiZY2BgYGAEAAAGAAKHf+MhAAAAAElFTkSuQmCC'
                                    width='400' />
                                <div class='lazy-loading' />
                            </a>
                            <b:else />
                            <a expr:href='data:post.link ?: data:post.url'>
                                <img class='image lazyload'
                                    expr:alt='data:post.title ? data:post.title : data:messages.image'
                                    expr:data-src='data:post.featuredImage.isResizable ? resizeImage(data:post.featuredImage, 400, &quot;1:1&quot;) : data:post.featuredImage'
                                    expr:srcset='resizeImage(data:post.featuredImage, 400, &quot;1:1&quot;) + &quot; 1x, &quot; + resizeImage(data:post.featuredImage, 800, &quot;1:1&quot;) + &quot; 2x&quot;'
                                    height='400'
                                    src='data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAABHNCSVQICAgIfAhkiAAAAAlwSFlzAAAD2AAAA9gBbkdjNQAAABl0RVh0U29mdHdhcmUAd3d3Lmlua3NjYXBlLm9yZ5vuPBoAAAANSURBVAiZY2BgYGAEAAAGAAKHf+MhAAAAAElFTkSuQmCC'
                                    width='400' />
                                <div class='lazy-loading' />

                            </a>
                        </b:if>
                        <b:else />
                        <a expr:href='data:post.url'>
                            <img class='image lazyload'
                                data-src='//1.bp.blogspot.com/-sLMytth04W8/XtoBMx9lUjI/AAAAAAAAHmM/zK-toM5XTacePvBHnpIO_tfzjg63BD3ZgCK4BGAsYHg/w400-h400-n-k-no-nu/nomage%2B%25281%2529.png'
                                expr:alt='data:post.title' expr:title='data:post.title'
                                height='400'
                                src='data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAABAAAAAJCAYAAAA7KqwyAAAABHNCSVQICAgIfAhkiAAAAAlwSFlzAAAD6AAAA+gBtXtSawAAABl0RVh0U29mdHdhcmUAd3d3Lmlua3NjYXBlLm9yZ5vuPBoAAAAYSURBVCiRY0xISOBgoAAwUaJ51IBhYwAAuQABOsYCprwAAAAASUVORK5CYII='
                                srcset='//1.bp.blogspot.com/-sLMytth04W8/XtoBMx9lUjI/AAAAAAAAHmM/zK-toM5XTacePvBHnpIO_tfzjg63BD3ZgCK4BGAsYHg/w400-h400-n-k-no-nu/nomage%2B%25281%2529.png 1x, //1.bp.blogspot.com/-sLMytth04W8/XtoBMx9lUjI/AAAAAAAAHmM/zK-toM5XTacePvBHnpIO_tfzjg63BD3ZgCK4BGAsYHg/w800-h800-n-k-no-nu/nomage%2B%25281%2529.png 2x'
                                width='400' />
                            <div class='lazy-loading' />
                        </a>
                    </b:if>
                    <b:if
                        cond='data:postDisplay.showTitle and data:postDisplay.showFeaturedImage'>
                    </b:if>
                </div>
            </div>
        </b:if>
    </b:includable>

    <b:includable id='featuredTitle'>
        <b:if cond='data:postDisplay.showTitle'>
            <h2>
                <a expr:href='data:post.link ?: data:post.url'>
                    <b:eval
                        expr='data:post.title ? data:post.title : data:messages.noTitle' />
                </a>
            </h2>
        </b:if>
    </b:includable>

    <b:includable id='featuredSnippet'>
        <b:if cond='data:postDisplay.showSnippet'>
            <p class='featured-desc'>
                <b:eval expr='snippet(data:post.snippets.long, { length: 120 })' />
            </p>
        </b:if>
    </b:includable>

    <b:includable id='featuredReadmore'>
        <p class='featured-more'>
            <a expr:href='data:post.url'>
                <data:messages.readMore />
                <span class='screen-reader-text'>
                    <data:post.title />
                </span>
            </a>
        </p>
    </b:includable>

</b:defaultmarkup>
<!-- WIDGET FEATURED POST END -->