<b:includable id='postReadMore'>
    <a class='read-more-link'
        expr:href='data:post.hasJumpLink ? data:post.url fragment &quot;more&quot; : data:post.url'
        expr:title='data:post.title'>
        <b:eval expr='data:blog.jumpLinkMessage' />
        <span class='screen-reader-text'>
            <data:post.title />
        </span>
    </a>
</b:includable>