<b:includable id='postInfo'>
    <div class='post-info'>
        <b:loop
            values='data:widgets.Blog.first.allBylineItems where (i =&gt; i.name == &quot;author&quot;)'
            var='byline'>
            <b:include name='postInfoAuthor' />
        </b:loop>
        <b:loop
            values='data:widgets.Blog.first.allBylineItems where (i =&gt; i.name == &quot;timestamp&quot;)'
            var='byline'>
            <b:include name='postInfoPostDate' />
        </b:loop>
        <b:include name='postInfoComment' />
    </div>
</b:includable>